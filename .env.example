# CyberSec MCP — Environment Configuration
# Copy to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# LLM provider API key (optional, for agentic orchestrators)
# LLM_API_KEY=sk-...

# MCP server: bypass AUP prompt in CI/CD pipelines
# Only set this if you have organizational approval for automated testing.
# CYBERSEC_MCP_AUP_ACCEPTED=1

# Rate limiter overrides (optional)
# CYBERSEC_MCP_RATE_LIMIT_MAX=100
# CYBERSEC_MCP_RATE_LIMIT_WINDOW_MS=60000
